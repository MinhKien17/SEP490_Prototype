# Copy this file to .env and replace placeholder values before running Docker Compose.
# Do not commit your real .env file.

# Database
MYSQL_ROOT_PASSWORD=changemerootpassword
MYSQL_DATABASE=evidence_pilot
MYSQL_USER=ep_user
MYSQL_PASSWORD=changemedbpassword
# Host port for MySQL (change if 3306 is already in use on your machine)
DB_PORT_HOST=3307

# Backend
BACKEND_PORT_HOST=8080
SERVER_PORT=8080
JWT_SECRET=changemetoalongrandomsecret
JWT_EXPIRATION_MS=86400000

# Default admin account
ADMIN_EMAIL=a@a.a
ADMIN_PASSWORD=string

# Email verification
# Use the frontend verification page URL. The backend appends ?token=...
EMAIL_VERIFICATION_URL=http://localhost:8080/verify-email
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=2

# Gmail SMTP
# MAIL_PASSWORD must be a Google App Password, not your normal Gmail password.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_google_app_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

# AI worker
AI_MODEL_BASE_URL=#https://ngrok-free.dev
AI_MODEL_API_KEY=your_ai_model_api_key
AI_MODEL_READ_TIMEOUT_SECONDS=600

# Qdrant
QDRANT_PORT_HOST=6333
